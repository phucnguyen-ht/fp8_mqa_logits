ninja_required_version = 1.3
cxx = /opt/rocm/bin/hipcc

cflags = -fno-strict-overflow -Wsign-compare -DNDEBUG -g -O2 -Wall -g -fstack-protector-strong -Wformat -Werror=format-security -g -fwrapv -O2 -fPIC -I/usr/local/lib/python3.12/dist-packages/torch/include -I/usr/local/lib/python3.12/dist-packages/torch/include/torch/csrc/api/include -I/usr/local/lib/python3.12/dist-packages/torch/include/THH -I/opt/rocm/include -I/usr/include/python3.12 -c
post_cflags = -D__HIP_PLATFORM_AMD__=1 -DUSE_ROCM=1 -DHIPBLAS_V2 -fPIC -D__HIP_PLATFORM_AMD__=1 -DUSE_ROCM=1 -DHIPBLAS_V2 -fPIC -O3 -DNDEBUG -std=c++17 --offload-arch=gfx942 -D__HIP_PLATFORM_AMD__=1 -DUSE_ROCM -Rpass-analysis=kernel-resource-usage -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=moreh_fp8_paged_mqa_logits
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc







